# PostgreSQL connection string (Neon / Vercel Postgres / Supabase).
# Use the POOLED connection string for serverless.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Admin/owner login. Employees log in with their own username + password
# (set by the admin in the employee form).
ADMIN_USERNAME="admin"
AUTH_PASSWORD="voltra-admin"

# Secret used to sign the session cookie (any long random string).
AUTH_SECRET="change-me-to-a-long-random-string"
